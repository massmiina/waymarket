generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(uuid())
  name                String
  email               String         @unique
  password            String?
  avatarUrl           String?
  memberSince         DateTime       @default(now())
  isPro               Boolean        @default(false)
  role                String         @default("USER")
  conversationsSeller Conversation[] @relation("SellerConversations")
  conversationsBuyer  Conversation[] @relation("BuyerConversations")
  favorites           Favorite[]
  listings            Listing[]      @relation("UserListings")
  messagesReceived    Message[]      @relation("MessagesReceived")
  messagesSent        Message[]      @relation("MessagesSent")
  isBanned            Boolean        @default(false)
  adminActions        AdminLog[]     @relation("AdminActions")
  subscriptions       SubscriptionRecord[]
}

model SubscriptionRecord {
  id        String   @id @default(uuid())
  userId    String
  amount    Float    @default(19.99)
  status    String   @default("SUCCEEDED") // SUCCEEDED, FAILED, PENDING
  plan      String   @default("PRO_MONTHLY")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String   // e.g. "BAN_USER", "PRO_TOGGLE", "DELETE_LISTING"
  details   String   // JSON string with more info
  createdAt DateTime @default(now())
  admin     User     @relation("AdminActions", fields: [adminId], references: [id], onDelete: Cascade)
}

model Listing {
  id            String         @id @default(uuid())
  title         String
  description   String
  price         Float
  category      String
  location      String
  images        String
  details       String?
  status        String         @default("ACTIVE")
  createdAt     DateTime       @default(now())
  sellerId      String
  conversations Conversation[]
  favoritedBy   Favorite[]
  seller        User           @relation("UserListings", fields: [sellerId], references: [id], onDelete: Cascade)
  messages      Message[]
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Conversation {
  id        String    @id @default(uuid())
  listingId String
  buyerId   String
  sellerId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  seller    User      @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  buyer     User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([listingId, buyerId, sellerId])
}

model Message {
  id             String       @id @default(uuid())
  content        String
  createdAt      DateTime     @default(now())
  status         String       @default("UNREAD")
  conversationId String
  senderId       String
  receiverId     String
  listingId      String
  listing        Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  receiver       User         @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model CarMake {
  id     String     @id @default(uuid())
  name   String     @unique
  slug   String     @unique
  models CarModel[]
}

model CarModel {
  id        String       @id @default(uuid())
  name      String
  slug      String
  makeId    String
  make      CarMake      @relation(fields: [makeId], references: [id], onDelete: Cascade)
  variants  CarVariant[]
  
  @@unique([name, makeId])
}

model CarVariant {
  id        String   @id @default(uuid())
  modelId   String
  year      Int
  trim      String?
  engine    String?
  fuelType  String?
  model     CarModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
}
